<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Dapper.AOT</id>
    <version>1.0.48</version>
    <authors>Marc Gravell</authors>
    <owners>Marc Gravell</owners>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <license type="expression">Apache-2.0</license>
    <licenseUrl>https://licenses.nuget.org/Apache-2.0</licenseUrl>
    <projectUrl>https://aot.dapperlib.dev/</projectUrl>
    <description>Build time (AOT) tools for Dapper</description>
    <copyright>Marc Gravell, 2021 onwards</copyright>
    <repository type="git" url="https://github.com/DapperLib/DapperAOT/" commit="4f8cd50639a4b1d489cdff0583d351578246c78e" />
    <dependencies>
      <group targetFramework=".NETFramework4.8">
        <dependency id="Microsoft.Bcl.AsyncInterfaces" version="9.0.1" exclude="Build,Analyzers" />
        <dependency id="System.Collections.Immutable" version="9.0.1" exclude="Build,Analyzers" />
        <dependency id="System.Memory" version="4.6.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETCoreApp3.1">
        <dependency id="System.Collections.Immutable" version="9.0.1" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETFramework6.0">
        <dependency id="System.Collections.Immutable" version="9.0.1" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETFramework8.0">
        <dependency id="System.Collections.Immutable" version="9.0.1" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETStandard2.0">
        <dependency id="Microsoft.Bcl.AsyncInterfaces" version="9.0.1" exclude="Build,Analyzers" />
        <dependency id="System.Collections.Immutable" version="9.0.1" exclude="Build,Analyzers" />
        <dependency id="System.Memory" version="4.6.0" exclude="Build,Analyzers" />
      </group>
    </dependencies>
    <icon>Dapper.png</icon>
    <readme>readme.md</readme>
  </metadata>
</package>