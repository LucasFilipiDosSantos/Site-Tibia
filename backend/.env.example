ASPNETCORE_ENVIRONMENT=Production
PORT=8080

# Render PostgreSQL external/internal connection string.
ConnectionStrings__DefaultConnection=Host=your-render-postgres-host;Port=5432;Database=your_db;Username=your_user;Password=your_password;SSL Mode=Require;Trust Server Certificate=true

# Frontend Hostinger origins. Separate more than one origin with comma.
CORS_ALLOWED_ORIGINS=https://seudominio.com.br,https://www.seudominio.com.br
Frontend__BaseUrl=https://seudominio.com.br

Jwt__Issuer=lootera-api
Jwt__Audience=lootera-web
Jwt__SigningKey=change-this-to-a-random-secret-with-at-least-32-characters

Hangfire__Enabled=true
Hangfire__WorkerCount=1

IdentityTokenDelivery__Provider=smtp
IdentityTokenDelivery__Smtp__Host=smtp.your-provider.com
IdentityTokenDelivery__Smtp__Port=587
IdentityTokenDelivery__Smtp__Username=change-me
IdentityTokenDelivery__Smtp__Password=change-me
IdentityTokenDelivery__Smtp__FromEmail=noreply@seudominio.com.br
IdentityTokenDelivery__Smtp__UseTls=true

MercadoPago__AccessToken=APP_USR-...
MercadoPago__PublicKey=APP_USR-...
MercadoPago__WebhookSecret=change-me
MercadoPago__NotificationUrl=https://seu-backend.onrender.com/payments/mercadopago/webhook
MercadoPago__SuccessUrl=https://seudominio.com.br/checkout/success
MercadoPago__FailureUrl=https://seudominio.com.br/checkout/failure
MercadoPago__PendingUrl=https://seudominio.com.br/checkout/pending

WhatsApp__BaseUrl=https://graph.facebook.com
WhatsApp__ApiVersion=v19.0
WhatsApp__AccessToken=change-me
WhatsApp__PhoneNumberId=change-me
WhatsApp__WhatsAppBusinessId=change-me
