DB_PASSWORD=change-this-postgres-password

JWT_SIGNING_KEY=change-this-to-a-random-secret-with-at-least-32-characters

MERCADO_PAGO_ACCESS_TOKEN=your-mercado-pago-access-token
MERCADO_PAGO_PUBLIC_KEY=your-mercado-pago-public-key
MERCADO_PAGO_WEBHOOK_SECRET=your-mercado-pago-webhook-secret
MERCADO_PAGO_NOTIFICATION_URL=https://api.seudominio.com.br/payments/mercadopago/webhook
MERCADO_PAGO_SUCCESS_URL=https://seudominio.com.br/checkout/success
MERCADO_PAGO_FAILURE_URL=https://seudominio.com.br/checkout/failure
MERCADO_PAGO_PENDING_URL=https://seudominio.com.br/checkout/pending

WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
WHATSAPP_BUSINESS_ID=your-whatsapp-business-id

SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=noreply@seudominio.com.br
SMTP_USE_TLS=true

FRONTEND_URL=https://lootera.com.br
CORS_ALLOWED_ORIGINS=https://lootera.com.br
FRONTEND_BASE_URL=https://lootera.com.br

HANGFIRE_ENABLED=true
HANGFIRE_WORKER_COUNT=1

# Keep false while only port 80 is configured. Set true after adding TLS/HTTPS.
HTTPS_ENABLED=false
